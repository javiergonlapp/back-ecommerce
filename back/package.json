{
  "name": "javier-shop-backend",
  "version": "2.0.0",
  "description": "JAVIER SHOP - Backend Enterprise",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/scripts/seed.js",
    "seed:products": "node src/scripts/seedProducts.js",
    "seed:categories": "node src/scripts/seedCategories.js",
    "seed:coupons": "node src/scripts/seedCoupons.js",
    "seed:admin": "node src/scripts/seedAdmin.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest src/tests/unit --runInBand --forceExit",
    "test:api": "jest src/tests/api --runInBand --forceExit"
  },
  "type": "commonjs",
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.15.0",
    "morgan": "^1.10.0",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "socket.io": "^4.8.1",
    "stripe": "^22.1.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.0"
  }
}
